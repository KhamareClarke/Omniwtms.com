# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# Organization/courier/customer dashboard sessions call Supabase Auth (password grant). Ensure:
# - All three vars above are from the SAME project
# - Dashboard → Authentication → Providers → Email is ON (sign-in with email + password allowed)

# Admin login (server-only): HTTP-only session cookie + email OTP to these addresses (comma-separated)
ADMIN_SESSION_SECRET=generate_a_random_string_at_least_32_chars
ADMIN_OTP_HMAC_SECRET=another_random_secret_at_least_16_chars
ADMIN_OTP_RECIPIENTS=admin-a@example.com,admin-b@example.com

# Mapbox Configuration (for maps and routing)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=your_mapbox_access_token

# Google Cloud Configuration (optional - for Vision API/OCR)
GOOGLE_CLOUD_PROJECT_ID=your_google_cloud_project_id
GOOGLE_CLOUD_PRIVATE_KEY=your_google_cloud_private_key
GOOGLE_CLOUD_CLIENT_EMAIL=your_google_cloud_client_email

# What3Words API (optional - for location services)
WHAT3WORDS_API_KEY=your_what3words_api_key

# OpenAI Configuration (optional - for AI features)
OPENAI_API_KEY=your_openai_api_key

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=OmniWTMS
# Optional label shown on /admin overview (default: Operational)
# NEXT_PUBLIC_PLATFORM_UPTIME_LABEL=All systems operational

# Email Configuration (for courier/customer notifications)
# Copy to .env.local and set your real values. Gmail: use App Password (no spaces).
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
# When true, outbound mail uses Go High Level (Private Integration Token + location id) instead of SMTP.
# USE_GHL_EMAIL=true
# Admin receives all delivery status and assignment notifications (default: clarkekhamare@gmail.com)
ADMIN_EMAIL=clarkekhamare@gmail.com

# Go High Level (SMS, optional email via conversations API)
# Prefer per-tenant ghl_location_id + ghl_api_key on tenants row (Settings → Notifications); optional global fallback:
# GHL_LOCATION_ID=
# GHL_API_KEY=
# GHL_API_BASE_URL=https://services.leadconnectorhq.com

# Protect GET/POST /api/payments/overdue-check (cron): Authorization: Bearer <CRON_SECRET>
# CRON_SECRET=your_random_secret

# Stripe (billing)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Dashboard → Developers → Webhooks → URL: https://<your-domain>/api/stripe/webhook
# Events: invoice.paid, invoice.payment_failed, customer.subscription.updated, payment_intent.succeeded, subscription_schedule.updated
# STRIPE_DEFAULT_PRICE_ID=price_...   (monthly price; new admin tenants + client signups bootstrap subscription when missing)
# Optional: NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# API usage telemetry (Edge middleware → POST /api/billing/log-api-call). Generate a long random string.
# TELEMETRY_SIGNING_SECRET=your_random_secret_at_least_32_chars

# Vercel Cron (vercel.json): GET /api/cron/billing-monthly and /api/cron/billing-overdue daily.
# When CRON_SECRET is set, send: Authorization: Bearer <CRON_SECRET> (configure the same value in Vercel env + cron job auth).
# Other hosts: schedule curl/wget with the same header.

# Webhook Configuration (optional)
WEBHOOK_SECRET=your_webhook_secret_key

# Analytics (optional)
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=your_google_analytics_id

# Environment
NODE_ENV=development

